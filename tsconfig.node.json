{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["electron-vite/node", "node"]
  },
  "include": ["electron.vite.config.ts", "electron/**/*.ts", "src/shared/**/*.ts"]
}
