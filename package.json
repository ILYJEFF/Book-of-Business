{
  "name": "book-of-business",
  "version": "1.0.0",
  "description": "Book of Business — local-first contact intelligence",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "icon:from-artwork": "sips --cropToHeightWidth 620 620 image.png --out /tmp/book-icon-crop.png && sips -z 1024 1024 /tmp/book-icon-crop.png --out build/icon.png && echo Updated build/icon.png (lower 620 = more zoom)"
  },
  "dependencies": {
    "@fontsource/literata": "^5.2.8",
    "@fontsource/spline-sans": "^5.2.8",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tz-lookup": "^6.1.25",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "~5.7.3",
    "vite": "^6.2.1"
  },
  "build": {
    "appId": "com.bookofbusiness.app",
    "productName": "Book of Business",
    "icon": "build/icon.png",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
